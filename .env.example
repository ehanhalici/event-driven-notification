# Insider Notification System - Environment Variables
# Copy this file to .env and update the values as needed:
#   cp .env.example .env

# PostgreSQL connection string (Docker internal: postgres, local: localhost)
DATABASE_URL=postgres://insider:secretpassword@postgres:5432/notifications_db

# Redis address (Docker internal: redis, local: localhost)
REDIS_URL=redis:6379

# Kafka broker address (Docker internal: kafka:29092, local: localhost:9092)
KAFKA_BROKER=kafka:29092

# Webhook URL for notification delivery (REQUIRED - no default allowed)
# Get your unique URL from https://webhook.site
WEBHOOK_URL=https://webhook.site/your-unique-uuid

# API server port
API_PORT=:8080

MAX_RETRIES=3